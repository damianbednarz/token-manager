{
  "name": "figma-token-replacer",
  "version": "1.0.0",
  "description": "A Figma plugin",
  "scripts": {
    "build": "npm run build:ui && npm run build:code && npm run copy:html",
    "build:ui": "esbuild src/ui.tsx --bundle --outfile=dist/ui.js --target=es2015 --format=iife --global-name=FigmaTokenReplacer",
    "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2015 --format=iife",
    "copy:html": "cp src/ui.html dist/ui.html",
    "watch": "npm run build:ui -- --watch & npm run build:code -- --watch",
    "dev": "npm run watch"
  },
  "dependencies": {
    "@figma/plugin-typings": "^1.90.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
